# ═══════════════════════════════════════════════════════════════════
# YDG — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
#   1. Copy this file to .env.local on your EC2 server
#   2. Replace ALL values marked with YOUR_... with your real values
#   3. NEVER commit this file to GitHub (it's in .gitignore)
# ═══════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://yourdigitalguy.co.za
NODE_ENV=production

# ── Database (AWS RDS PostgreSQL) ────────────────────────────────────
# Format: postgresql://USERNAME:PASSWORD@RDS_ENDPOINT:5432/DB_NAME
# Find RDS endpoint in: AWS Console → RDS → Databases → your DB → Connectivity
DATABASE_URL=postgresql://ydg_user:YOUR_RDS_PASSWORD@YOUR_RDS_ENDPOINT.af-south-1.rds.amazonaws.com:5432/ydg_db

# ── Redis (AWS ElastiCache) ──────────────────────────────────────────
# Find endpoint in: AWS Console → ElastiCache → Clusters → your cluster
REDIS_URL=redis://YOUR_ELASTICACHE_ENDPOINT.cache.amazonaws.com:6379

# ── NextAuth ─────────────────────────────────────────────────────────
# Secret below is pre-generated — keep it safe, don't change after launch
NEXTAUTH_SECRET=QzHnHNI/ue5BguZml2+7qPVXpm5hGUnChRvU0LKug3A=
NEXTAUTH_URL=https://yourdigitalguy.co.za

# ── AI APIs ──────────────────────────────────────────────────────────
# Anthropic (Claude) → https://console.anthropic.com/keys
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# OpenAI (GPT-4o) → https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Google Gemini → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── YOCO Payments ─────────────────────────────────────────────────────
# Dashboard → https://dashboard.yoco.com/developers
YOCO_SECRET_KEY=sk_live_YOUR_YOCO_SECRET_KEY
YOCO_PUBLIC_KEY=pk_live_YOUR_YOCO_PUBLIC_KEY
YOCO_WEBHOOK_SECRET=YOUR_YOCO_WEBHOOK_SECRET

# ── AWS Services ──────────────────────────────────────────────────────
# Create IAM user with S3 + SES permissions
# AWS Console → IAM → Users → Create user → Attach: AmazonS3FullAccess + AmazonSESFullAccess
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=YOUR_IAM_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_IAM_SECRET_KEY
AWS_S3_BUCKET=ydg-media-bucket

# ── AWS SES (Email) ───────────────────────────────────────────────────
# Verify this email in AWS SES before using
# AWS Console → SES → Verified identities → Create identity
AWS_SES_FROM_EMAIL=YOUR_EMAIL@yourdigitalguy.co.za

# ── Google (Optional) ─────────────────────────────────────────────────
GOOGLE_SITE_VERIFICATION=YOUR_GOOGLE_VERIFICATION_CODE
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Error Tracking (Optional — Sentry) ────────────────────────────────
SENTRY_DSN=
