# ─── YDG Environment Variables ────────────────────────────────────────────────
# Copy this file to .env.local for development
# Add all values to AWS Secrets Manager / EC2 environment for production

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://yourdigitalguy.co.za
NODE_ENV=production

# ─── Database ──────────────────────────────────────────────────────────────────
# AWS RDS PostgreSQL
DATABASE_URL=postgresql://ydg_user:YOUR_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/ydg_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
# AWS ElastiCache
REDIS_URL=redis://your-elasticache-endpoint.cache.amazonaws.com:6379

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING
NEXTAUTH_URL=https://yourdigitalguy.co.za

# ─── OAuth (Optional) ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ─── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# ─── YOCO Payments ─────────────────────────────────────────────────────────────
YOCO_SECRET_KEY=sk_live_YOUR_YOCO_SECRET_KEY
YOCO_PUBLIC_KEY=pk_live_YOUR_YOCO_PUBLIC_KEY
YOCO_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
AWS_S3_BUCKET=ydg-media-bucket
AWS_SES_FROM_EMAIL=hallo@yourdigitalguy.co.za

# ─── Google Search Console ──────────────────────────────────────────────────────
GOOGLE_SITE_VERIFICATION=YOUR_VERIFICATION_CODE
GOOGLE_SEARCH_CONSOLE_KEY=YOUR_KEY

# ─── Sentry (Error Tracking) ───────────────────────────────────────────────────
SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT
